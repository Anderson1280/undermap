# ─── Google Places API ────────────────────────────────────────────────────────
# Obtenha em: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_API_KEY=

# ─── SMTP (envio de e-mails) ──────────────────────────────────────────────────
# Recomendado: conta Gmail com App Password (não use senha normal)
# Tutorial: myaccount.google.com → Segurança → Senhas de app
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASSWORD=

# ─── Remetente nos e-mails ────────────────────────────────────────────────────
SENDER_NAME=Seu Nome
SENDER_EMAIL=seuemail@gmail.com

# ─── Backend de licenças (Fase 2 — deixe vazio no MVP local) ─────────────────
LICENSE_API_URL=
LICENSE_SECRET=

# ─── Banco de dados local ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///undermap.db
